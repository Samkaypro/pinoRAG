# pinoRAG .env file
# Spring Boot reads this on startup via spring.config.import in application.yaml.
# Treated as a Java properties file. KEY=VALUE pairs work; no shell semantics,
# no quoting required. Copy to .env and fill in the real values.

# Postgres (used by docker compose AND the app)
POSTGRES_DB=pinorag
POSTGRES_USER=pinorag
POSTGRES_PASSWORD=pinorag
POSTGRES_PORT=5432

# App
APP_PORT=8080
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/pinorag
SPRING_DATASOURCE_USERNAME=pinorag
SPRING_DATASOURCE_PASSWORD=pinorag
SPRING_DATASOURCE_MAX_POOL_SIZE=20
SPRING_DATASOURCE_MIN_IDLE=2

# Auth: REQUIRED for prod. 32+ bytes of random.
# Generate with: openssl rand -base64 48
PINORAG_JWT_SECRET=change-me-change-me-change-me-change-me-change-me-32b
PINORAG_JWT_ISSUER=
PINORAG_JWT_CLOCK_SKEW_SECONDS=30
PINORAG_API_KEY_TOUCH_FLUSH_MILLIS=10000

# Rate limits per API key (authenticated requests)
PINORAG_RATE_LIMIT_RPM=60
PINORAG_RATE_LIMIT_BURST=60
# Rate limit per source IP for unauthenticated requests
PINORAG_ANON_RATE_LIMIT_RPM=30

# Ingest
PINORAG_UPLOAD_DIR=/opt/pino/uploads
PINORAG_MAX_UPLOAD_BYTES=25MB
PINORAG_MAX_UPLOAD_BYTES_RAW=26214400
PINORAG_CHUNK_SIZE=1000
PINORAG_CHUNK_OVERLAP=200
PINORAG_EMBEDDING_BATCH_SIZE=16

# Provider selection
PINORAG_EMBEDDER_ID=fake
PINORAG_CHUNKER_ID=fixed
PINORAG_LLM_ID=fake

# Query (vector search + LLM generation)
PINORAG_QUERY_TOP_K=5
PINORAG_QUERY_MIN_SCORE=0.65
PINORAG_QUERY_CONTEXT_TOKENS=3000
PINORAG_QUERY_MAX_ANSWER_TOKENS=512
PINORAG_QUERY_TEMPERATURE=0.2
# REFUSE | LLM_ONLY | MESSAGE
PINORAG_QUERY_FALLBACK_MODE=REFUSE
PINORAG_QUERY_FALLBACK_MESSAGE=I do not have enough context to answer that.
PINORAG_QUERY_SSE_TIMEOUT_MS=300000
PINORAG_QUERY_LLM_TIMEOUT_MS=60000
# Retrieval backend: VECTOR (cosine only), BM25 (postgres full-text only), HYBRID (RRF of both)
PINORAG_QUERY_RETRIEVAL_MODE=HYBRID

# Ollama (only used if PINORAG_EMBEDDER_ID=ollama or PINORAG_LLM_ID=ollama)
SPRING_AI_OLLAMA_BASE_URL=http://localhost:11434

# Docker
OLLAMA_PORT=11434
