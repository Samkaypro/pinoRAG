<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <!--
        SecretMaskingConverter is wired into both the dev pattern (via the
        %masked conversion word below) and the prod JSON output (via the
        MaskingMessageJsonProvider in the prod profile). Both routes share
        the same set of regex patterns and stay in sync if the converter
        adds a new pattern.
    -->
    <conversionRule conversionWord="masked"
                    class="io.pinoRAG.observability.SecretMaskingConverter"/>

    <springProfile name="!prod &amp; !production">
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] %logger{40} - %masked%n</pattern>
            </encoder>
        </appender>
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
        <logger name="io.pinoRAG" level="DEBUG"/>
    </springProfile>

    <springProfile name="prod | production">
        <appender name="JSON" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="net.logstash.logback.encoder.LoggingEventCompositeJsonEncoder">
                <providers>
                    <timestamp>
                        <fieldName>ts</fieldName>
                    </timestamp>
                    <logLevel>
                        <fieldName>level</fieldName>
                    </logLevel>
                    <loggerName>
                        <fieldName>logger</fieldName>
                    </loggerName>
                    <threadName>
                        <fieldName>thread</fieldName>
                    </threadName>
                    <mdc/>
                    <!-- Custom provider: masks secrets before writing the message field. -->
                    <provider class="io.pinoRAG.observability.MaskingMessageJsonProvider">
                        <fieldName>msg</fieldName>
                    </provider>
                    <stackTrace>
                        <fieldName>stack</fieldName>
                    </stackTrace>
                </providers>
            </encoder>
        </appender>
        <root level="INFO">
            <appender-ref ref="JSON"/>
        </root>
        <logger name="io.pinoRAG" level="INFO"/>
    </springProfile>
</configuration>
