<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <!--
        SecretMaskingConverter is wired into the dev/test pattern via %masked.
        Prod profile uses LogstashEncoder which renders the message field
        through its own JsonProvider chain; making %masked apply to the
        JSON output requires a custom JsonProvider that wraps the formatted
        message. That work is tracked under observability and
        intentionally not landed here so the broken-config from the v0
        attempt does not block JSON logging.
    -->
    <conversionRule conversionWord="masked"
                    class="io.pinoRAG.observability.SecretMaskingConverter"/>

    <springProfile name="!prod &amp; !production">
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] %logger{40} - %masked%n</pattern>
            </encoder>
        </appender>
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
        <logger name="io.pinoRAG" level="DEBUG"/>
    </springProfile>

    <springProfile name="prod | production">
        <appender name="JSON" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="net.logstash.logback.encoder.LogstashEncoder">
                <includeContext>false</includeContext>
                <includeMdc>true</includeMdc>
                <fieldNames>
                    <timestamp>ts</timestamp>
                    <message>msg</message>
                    <logger>logger</logger>
                    <thread>thread</thread>
                    <level>level</level>
                    <stackTrace>stack</stackTrace>
                </fieldNames>
            </encoder>
        </appender>
        <root level="INFO">
            <appender-ref ref="JSON"/>
        </root>
        <logger name="io.pinoRAG" level="INFO"/>
    </springProfile>
</configuration>
